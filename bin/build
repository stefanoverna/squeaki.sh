#!/usr/bin/env bash

set -e

# If .env exists (local dev), use dotenv to load it
# In CI, env vars are already set by the build environment
if [ -f .env ]; then
  DOTENV="dotenv -e .env --"
else
  DOTENV=""
  # Generate .dev.vars from env vars for the workerd prerender server
  env | grep '^PRIVATE_' > .dev.vars 2>/dev/null || true
fi

# Update Mastodon URLs in content
$DOTENV tsx ./scripts/update-mastodon-urls.ts

# Build the site
$DOTENV astro build
